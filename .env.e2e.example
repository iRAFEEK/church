# Copy to .env.e2e (git-ignored) and point at a DISPOSABLE test Supabase project.
# Never set these to production. Values below match supabase/seed_data.sql.
#
#   set -a; source .env.e2e; set +a
#   npm run test:e2e

E2E_BASE_URL=http://localhost:3000

# A member-role user who has completed onboarding
E2E_MEMBER_EMAIL=member@gracechurch.test
E2E_MEMBER_PASSWORD=password123

# A super_admin user
E2E_ADMIN_EMAIL=pastor@gracechurch.test
E2E_ADMIN_PASSWORD=password123

# A group_leader and a ministry_leader (drive the persona feature matrix)
E2E_LEADER_EMAIL=leader1@gracechurch.test
E2E_LEADER_PASSWORD=password123
E2E_MINLEADER_EMAIL=worship@gracechurch.test
E2E_MINLEADER_PASSWORD=password123

# Real ids in the test DB for deep-link probes in the persona matrix
E2E_MEMBER_ID=
E2E_GROUP_ID=
E2E_MINISTRY_ID=
E2E_EVENT_ID=

# A user with onboarding_completed = false (drives the onboarding-gate spec)
E2E_ONBOARDING_EMAIL=newmember@gracechurch.test
E2E_ONBOARDING_PASSWORD=password123

# A church id present in the test DB (drives the public /join intake spec)
E2E_CHURCH_ID=a0000000-0000-0000-0000-000000000001
