# =============================================================================
# Ekklesia — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# Required variables are marked with [REQUIRED].
# Optional variables are marked with [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# Platform Administration
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma-separated list of platform-admin emails. These users (outside the
# per-church RBAC system) can review and approve/reject newly registered churches at
# /platform/churches. Leave empty in environments that don't need the review queue.
# Example: PLATFORM_ADMIN_EMAILS=founder@ekklesia.app,ops@ekklesia.app
PLATFORM_ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# [REQUIRED] Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anonymous/public API key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service role key — server-side only, never expose to client
# Used for admin operations that bypass RLS (found in Project Settings > API)
SUPABASE_SERVICE_ROLE_KEY=

# [REQUIRED] Direct PostgreSQL connection string for Supabase
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# [REQUIRED] Public-facing app URL (used for links in emails, redirects, etc.)
# Example: https://your-app.vercel.app or http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Firebase — Push Notifications (FCM)
# -----------------------------------------------------------------------------

# [REQUIRED] Firebase client-side config (found in Firebase Console > Project Settings > General > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# [REQUIRED] Firebase VAPID key for web push (found in Firebase Console > Cloud Messaging > Web configuration)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# [REQUIRED] Firebase Admin SDK credentials — server-side only
# Used to send push notifications via FCM (found in Firebase Console > Project Settings > Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Resend — Email (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Resend API key for transactional emails (https://resend.com)
RESEND_API_KEY=

# [OPTIONAL] Sender email address for outgoing emails
# Example: noreply@yourchurch.com
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# WhatsApp Messaging (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] WhatsApp Business API key for messaging
WHATSAPP_API_KEY=

# [OPTIONAL] WhatsApp Business API endpoint URL
WHATSAPP_API_URL=

# [OPTIONAL] Secret for verifying incoming WhatsApp webhook requests
WHATSAPP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Phone / WhatsApp OTP Login (Optional — enables phone sign-in)
# -----------------------------------------------------------------------------
# Delivers Supabase phone-OTP codes over the Meta WhatsApp Cloud API (direct).
# Supabase generates/verifies the code and mints the session via the Send-SMS
# auth hook; these vars only configure delivery. See docs/WHATSAPP_OTP_SETUP.md.
# Leave UNSET in local dev — the sender falls back to logging the OTP so you can
# test with Supabase test-OTP numbers.

# [OPTIONAL] Meta WhatsApp Cloud API phone-number ID (from the WhatsApp app in
# Meta for Developers — NOT the display phone number)
WHATSAPP_PHONE_NUMBER_ID=

# [OPTIONAL] Permanent system-user access token for the Cloud API (Bearer token)
WHATSAPP_ACCESS_TOKEN=

# [OPTIONAL] Name of the approved authentication-category template (default: otp_login)
WHATSAPP_OTP_TEMPLATE=otp_login

# [OPTIONAL] Standard Webhooks secret for the Supabase Send-SMS hook.
# Format: "v1,whsec_<base64>" — copy it from Supabase Auth → Hooks → Send SMS.
# The /api/auth/sms-hook endpoint fails CLOSED (403) when this is unset.
SEND_SMS_HOOK_SECRET=

# -----------------------------------------------------------------------------
# Cron Jobs (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret token to authenticate cron job requests (e.g., event reminders, visitor SLA checks)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Upstash Redis — Distributed rate limiting (Recommended for production)
# -----------------------------------------------------------------------------
# When BOTH are set, rate limiting is enforced across all serverless instances
# (correct on Vercel). When unset, the app falls back to a per-instance
# in-memory limiter (fine for local dev, weak under real serverless traffic).
# Create a free database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# PostHog — Analytics (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] PostHog project API key (found in PostHog > Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=

# [OPTIONAL] PostHog ingestion host
# Use https://eu.i.posthog.com for EU data residency or https://us.i.posthog.com for US
NEXT_PUBLIC_POSTHOG_HOST=

# [OPTIONAL] PostHog project API key for server-side usage (same value as NEXT_PUBLIC_POSTHOG_KEY)
POSTHOG_PROJECT_API_KEY=

# -----------------------------------------------------------------------------
# Sentry — Error Tracking (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Sentry DSN for error tracking (found in Sentry > Project Settings > Client Keys)
NEXT_PUBLIC_SENTRY_DSN=

# [OPTIONAL] Sentry organization slug (for source map uploads during build)
SENTRY_ORG=

# [OPTIONAL] Sentry project slug (for source map uploads during build)
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Finance module — default OFF everywhere (in development).
# Set to "true" to re-enable the finance surface (nav, pages, /api/finance/*).
NEXT_PUBLIC_FEATURE_FINANCE=

# [OPTIONAL] Event templates module — default OFF in production; enabled on
# staging/local (see scripts/dev-staging.sh). Set to "true" to enable the
# templates surface (nav, /admin/templates*, /admin/events/from-template,
# /api/templates*, /api/events/from-template).
NEXT_PUBLIC_FEATURE_TEMPLATES=
