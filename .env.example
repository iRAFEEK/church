# =============================================================================
# Ekklesia — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# Required variables are marked with [REQUIRED].
# Optional variables are marked with [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# [REQUIRED] Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED] Supabase anonymous/public API key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service role key — server-side only, never expose to client
# Used for admin operations that bypass RLS (found in Project Settings > API)
SUPABASE_SERVICE_ROLE_KEY=

# [REQUIRED] Direct PostgreSQL connection string for Supabase
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# [REQUIRED] Public-facing app URL (used for links in emails, redirects, etc.)
# Example: https://your-app.vercel.app or http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Firebase — Push Notifications (FCM)
# -----------------------------------------------------------------------------

# [REQUIRED] Firebase client-side config (found in Firebase Console > Project Settings > General > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# [REQUIRED] Firebase VAPID key for web push (found in Firebase Console > Cloud Messaging > Web configuration)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# [REQUIRED] Firebase Admin SDK credentials — server-side only
# Used to send push notifications via FCM (found in Firebase Console > Project Settings > Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Resend — Email (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Resend API key for transactional emails (https://resend.com)
RESEND_API_KEY=

# [OPTIONAL] Sender email address for outgoing emails
# Example: noreply@yourchurch.com
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# WhatsApp Messaging (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] WhatsApp Business API key for messaging
WHATSAPP_API_KEY=

# [OPTIONAL] WhatsApp Business API endpoint URL
WHATSAPP_API_URL=

# [OPTIONAL] Secret for verifying incoming WhatsApp webhook requests
WHATSAPP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Cron Jobs (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] Secret token to authenticate cron job requests (e.g., event reminders, visitor SLA checks)
CRON_SECRET=

# -----------------------------------------------------------------------------
# PostHog — Analytics (Optional)
# -----------------------------------------------------------------------------

# [OPTIONAL] PostHog project API key (found in PostHog > Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=

# [OPTIONAL] PostHog ingestion host
# Use https://eu.i.posthog.com for EU data residency or https://us.i.posthog.com for US
NEXT_PUBLIC_POSTHOG_HOST=

# [OPTIONAL] PostHog project API key for server-side usage (same value as NEXT_PUBLIC_POSTHOG_KEY)
POSTHOG_PROJECT_API_KEY=
